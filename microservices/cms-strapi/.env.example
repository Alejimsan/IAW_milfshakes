# Strapi Core
NODE_ENV=production
HOST=0.0.0.0
PORT=1337
APP_KEYS=your_app_keys_here_generate_random_strings
JWT_SECRET=your_jwt_secret_here_generate_random_string
ADMIN_JWT_SECRET=your_admin_jwt_secret_here_generate_random_string
API_TOKEN_SALT=your_api_token_salt_here_generate_random_string

# Database Connection
DATABASE_CLIENT=postgres
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=strapi_milfshakes
DATABASE_USERNAME=strapi
DATABASE_PASSWORD=strapi_password_change_in_production
DATABASE_SSL=false
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# API Configuration
API_URL=http://localhost:1337
ADMIN_URL=http://localhost:1337/admin

# Vercel / Production
DATABASE_URL=postgresql://user:password@host:5432/database

# CORS
STRAPI_ADMIN_BACKEND_URL=http://localhost:1337
STRAPI_ADMIN_FRONTEND_URL=http://localhost:3001

# Public API access
STRAPI_DISABLE_ADMIN_AUTH=false
