<% include('layout', { body: (function(){ %>
  <h2>Carrito</h2>
  <% if (items.length === 0) { %>
    <p>Tu carrito está vacío.</p>
  <% } else { %>
    <table class="cart-table">
      <thead><tr><th>Producto</th><th>Precio</th><th>Cantidad</th><th>Subtotal</th></tr></thead>
      <tbody>
        <% items.forEach(function(it){ %>
          <tr>
            <td><%= it.name %></td>
            <td>€<%= it.price.toFixed(2) %></td>
            <td><%= it.qty %></td>
            <td>€<%= it.subtotal.toFixed(2) %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
    <p class="total">Total: €<%= total.toFixed(2) %></p>
    <form action="/checkout" method="post"><button type="submit">Finalizar compra (demo)</button></form>
  <% } %>
<% })() }) %>
